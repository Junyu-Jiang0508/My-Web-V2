---
import Layout from '../layouts/Layout.astro';
import SelectedPubs from '../components/SelectedPubs.astro';
import profile from '../data/profile.json';

const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '') || '';

// Convert display email (e.g. "x[at]y[dot]com") to mailto format
const getMailtoLink = (email: string) =>
  email.replace(/\[at\]/g, '@').replace(/\[dot\]/g, '.');

// Inject links into bio
const linkClass = 'text-blue-600 underline decoration-blue-300 underline-offset-2 hover:text-blue-800 hover:decoration-blue-500';
const makeLink = (text: string, url: string) =>
  `<a href="${url}" target="_blank" rel="noopener noreferrer" class="${linkClass}">${text}</a>`;

const bioWithLinks = profile.bio
  .replace('Ukrainian Poetry Digital Archive', makeLink('Ukrainian Poetry Digital Archive', 'https://www.ukrpoetry.org/'))
  .replace('Prof. Amelia Glasser', makeLink('Prof. Amelia Glasser', 'https://literature.ucsd.edu/people/faculty/aglaser.html'))
  .replace('Computational Social Science at UC San Diego', makeLink('Computational Social Science at UC San Diego', 'https://css.ucsd.edu/masters/index.html'))
  .replace('Communication University of China', makeLink('Communication University of China', 'https://en.cuc.edu.cn/'))
  .replace('University of Missouri-Columbia', makeLink('University of Missouri-Columbia', 'https://journalism.missouri.edu/'));

const socialLinks = [
  profile.email && { label: 'Email', href: `mailto:${getMailtoLink(profile.email)}`, icon: 'email' },
  profile.github && { label: 'GitHub', href: profile.github, icon: 'github' },
  profile.googleScholar && { label: 'Google Scholar', href: profile.googleScholar, icon: 'scholar' },
  profile.orcid && { label: 'ORCID', href: profile.orcid, icon: 'orcid' },
  profile.twitter && { label: 'Twitter/X', href: profile.twitter, icon: 'twitter' },
].filter(Boolean);
---

<Layout title={profile.name}>
	<section class="hero-section px-4 py-16 md:py-24">
		<div class="mx-auto flex max-w-4xl flex-col items-center gap-12 md:flex-row md:items-start md:gap-16">
			<!-- Avatar: larger size, rectangular, aligned with reference layout -->
			<div class="flex-shrink-0 w-56 md:w-72">
				<img
					src={profile.avatar.startsWith('http') ? profile.avatar : new URL(profile.avatar.startsWith('/') ? profile.avatar : '/' + profile.avatar, import.meta.env.SITE).href}
					alt={profile.name}
					class="w-full h-auto object-contain"
				/>
			</div>

			<!-- Content -->
			<div class="flex flex-1 flex-col text-center md:text-left">
				<h1 class="text-3xl font-bold tracking-tight text-gray-900 md:text-4xl">
					{profile.name}
				</h1>
				<p class="mt-2 text-lg font-medium text-gray-700">
					{profile.position}
				</p>
				<p class="mt-1 text-base text-gray-600">
					{profile.school}
				</p>
				<p class="mt-4 max-w-xl text-base leading-relaxed text-gray-600" set:html={bioWithLinks} />
				<p class="mt-2 max-w-xl text-sm text-gray-500">
					<em>Name pronunciation (IPA):</em> {profile.namePronunciation}
				</p>

				<!-- Social Links -->
				<div class="mt-6 flex flex-wrap justify-center gap-3 md:justify-start">
					{socialLinks.map((link) => (
						<a
							href={link.href}
							target={link.href.startsWith('mailto') ? undefined : '_blank'}
							rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
							class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-2.5 text-sm font-medium text-gray-700 transition-colors hover:border-gray-300 hover:bg-gray-50"
							aria-label={link.label}
						>
							{link.icon === 'email' && (
								<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
								</svg>
							)}
							{link.icon === 'github' && (
								<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
									<path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
								</svg>
							)}
							{link.icon === 'scholar' && (
								<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
									<path d="M12 24a7 7 0 110-14 7 7 0 010 14zm0-24L0 9.5l4.838 3.94A8 8 0 0112 9a8 8 0 017.162 4.44L12 24z" />
								</svg>
							)}
							{link.icon === 'orcid' && (
								<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
									<path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zm-2 8.5v7h-2v-7h2zm1 0c.828 0 1.5.672 1.5 1.5S11.828 11.5 11 11.5 9.5 10.828 9.5 10s.672-1.5 1.5-1.5zm4 3.5c0-1.933-1.567-3.5-3.5-3.5S8 10.567 8 12.5 9.567 16 11.5 16c.914 0 1.755-.354 2.371-.933l-.006.006 1.135-1.135c-.793.793-1.871 1.285-3.062 1.285-2.209 0-4-1.791-4-4s1.791-4 4-4 4 1.791 4 4h-2z" />
								</svg>
							)}
							{link.icon === 'twitter' && (
								<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
									<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
								</svg>
							)}
							{link.label}
						</a>
					))}
				</div>

			</div>
		</div>
	</section>

	<SelectedPubs />
</Layout>
