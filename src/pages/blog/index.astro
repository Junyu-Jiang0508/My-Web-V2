---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const site = import.meta.env.SITE || 'https://junyuj.com';
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// 按年份分组
const postsByYear = posts.reduce<Record<number, typeof posts>>((acc, post) => {
  const year = post.data.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});

// 提取所有标签（Research Keywords）
const allTags = [...new Set(posts.flatMap((p) => p.data.tags || []))].sort();

const sortedYears = Object.keys(postsByYear)
  .map(Number)
  .sort((a, b) => b - a);

// 格式化日期为 "Mar 05"
const formatShortDate = (date: Date) => {
  const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  return `${months[date.getMonth()]} ${date.getDate().toString().padStart(2, '0')}`;
};
---

<Layout title="Blog" fullWidth={true}>
  <div class="blog-container px-4 py-12 md:py-16">
    <aside class="blog-sidebar" aria-label="Table of contents">
      <nav class="blog-toc">
        <p class="blog-toc-label">Years</p>
        <div class="blog-toc-links">
          {sortedYears.map((year) => (
            <a href={`#year-${year}`} class="blog-toc-link" data-year={year}>
              {year}
            </a>
          ))}
        </div>
        {allTags.length > 0 && (
          <div class="blog-keywords">
            <p class="blog-keywords-label">Research Keywords</p>
            <div class="blog-keywords-tags">
              {allTags.map((tag) => (
                <span class="blog-keyword-tag">{tag}</span>
              ))}
            </div>
          </div>
        )}
      </nav>
    </aside>

    <main class="blog-main">
      <h1 class="blog-list-heading">Blog Posts</h1>
      {(() => {
        let animOrder = 0;
        return sortedYears.map((year) => (
          <section class="blog-list-section" id={`year-${year}`}>
            <h2 class="blog-list-year">{year}</h2>
            <div class="blog-list-posts">
              {postsByYear[year].map((post) => (
                <article class="blog-list-article" style={`--anim-order: ${animOrder++}`}>
                  <time class="blog-list-date" datetime={post.data.date.toISOString()}>
                    {formatShortDate(post.data.date)}
                  </time>
                  <div class="blog-list-main">
                    <a href={`${site}/blog/${post.id}.html`} class="blog-list-title">
                      {post.data.title}
                    </a>
                    <div class="blog-list-tags">
                      {post.data.tags?.map((tag) => (
                        <span class="blog-list-tag">{tag}</span>
                      )) ?? null}
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ));
      })()}
    </main>
  </div>

  <script>
    function initBlogScrollSpy() {
      const sections = document.querySelectorAll('.blog-list-section[id^="year-"]');
      const links = document.querySelectorAll('.blog-toc-link');
      if (sections.length === 0 || links.length === 0) return;

      const observerOptions = { rootMargin: '-100px 0px -60% 0px', threshold: 0 };
      const visible = new Map();

      function updateActive() {
        const intersecting = [...sections].filter((s) => visible.get(s.id));
        const sorted = intersecting.sort(
          (a, b) => a.getBoundingClientRect().top - b.getBoundingClientRect().top
        );
        const activeId = sorted[0]?.id || '';

        links.forEach((link) => {
          const targetId = (link.getAttribute('href') || '').slice(1);
          link.classList.toggle('active', targetId === activeId);
        });
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            visible.set(entry.target.id, entry.isIntersecting);
          });
          updateActive();
        },
        observerOptions
      );

      sections.forEach((s) => observer.observe(s));
    }

    document.addEventListener('DOMContentLoaded', initBlogScrollSpy);
    document.addEventListener('astro:page-load', initBlogScrollSpy);
  </script>
</Layout>

<style>
  .blog-container {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 3rem;
    max-width: 56rem;
    margin: 0 auto;
  }

  @media (max-width: 767px) {
    .blog-container {
      grid-template-columns: 1fr;
    }

    .blog-sidebar {
      display: none;
    }
  }

  .blog-sidebar {
    position: sticky;
    top: 6rem;
    height: fit-content;
  }

  .blog-toc {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .blog-toc-label,
  .blog-keywords-label {
    font-family: Inter, system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.5rem 0;
  }

  .blog-toc-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .blog-toc-link {
    display: block;
    padding: 0.4rem 0 0.4rem 1rem;
    border-left: 2px solid #eee;
    font-family: "JetBrains Mono", ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
    font-size: 0.875rem;
    font-weight: 500;
    color: #999;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .blog-toc-link:hover {
    color: #555;
  }

  .blog-toc-link.active {
    border-left-color: #1a1a1a;
    color: #1a1a1a;
    font-weight: 700;
  }

  .blog-keywords {
    padding-top: 1rem;
    border-top: 1px solid #eee;
  }

  .blog-keywords-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .blog-keyword-tag {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.6875rem;
    color: #737373;
    padding: 0.2rem 0.4rem;
    background: #f5f5f5;
    border-radius: 0.2rem;
  }

  .blog-main {
    min-width: 0;
  }

  .blog-list-academic {
    --accent: #2c5282;
    color: #1a1a1a;
  }

  .blog-list-heading {
    font-family: "Times New Roman", "SimSun", "宋体", serif;
    font-size: 2rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 3rem;
    letter-spacing: -0.02em;
  }

  .blog-list-section {
    margin-bottom: 3rem;
    scroll-margin-top: 6rem;
  }

  .blog-list-year {
    font-family: Inter, system-ui, -apple-system, sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #737373;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.25rem;
  }

  .blog-list-posts {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .blog-list-article {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1.5rem;
    align-items: start;
    padding: 1rem 1.25rem;
    margin: 0 -1.25rem;
    border-radius: 0.375rem;
    cursor: pointer;
    transition: background 0.2s ease;
    animation: blog-slide-in 0.5s ease-out both;
    animation-delay: calc(var(--anim-order, 0) * 0.06s);
  }

  .blog-list-article:hover {
    background: #f5f5f5;
  }

  .blog-list-article:hover .blog-list-title {
    text-decoration: underline;
    text-underline-offset: 3px;
    color: var(--accent);
  }

  @keyframes blog-slide-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .blog-list-date {
    width: 80px;
    flex-shrink: 0;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
    font-size: 0.8125rem;
    color: #737373;
    padding-top: 0.125rem;
  }

  .blog-list-main {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .blog-list-title {
    font-family: "Times New Roman", "SimSun", "宋体", serif;
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1a1a1a;
    text-decoration: none;
    transition: color 0.2s ease, text-decoration 0.2s ease;
    line-height: 1.4;
  }

  .blog-list-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .blog-list-tag {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    font-weight: 500;
    color: #525252;
    background: #e8e8e8;
    padding: 0.2rem 0.5rem;
    border-radius: 0.2rem;
    border: 1px solid #e0e0e0;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .blog-list-article:hover .blog-list-tag {
    background: #e0e0e0;
    border-color: #d4d4d4;
  }
</style>
