---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const site = import.meta.env.SITE || 'https://junyuj.com';
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// 按年份分组
const postsByYear = posts.reduce<Record<number, typeof posts>>((acc, post) => {
  const year = post.data.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});

// 格式化日期为 "Mar 05"
const formatShortDate = (date: Date) => {
  const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  return `${months[date.getMonth()]} ${date.getDate().toString().padStart(2, '0')}`;
};
---

<Layout title="Blog">
  <div class="blog-list-academic px-4 py-12 md:py-16">
    <h1 class="blog-list-heading">Blog Posts</h1>
    {(() => {
      let animOrder = 0;
      return Object.entries(postsByYear)
        .sort(([a], [b]) => Number(b) - Number(a))
        .map(([year, yearPosts]) => (
          <section class="blog-list-section">
            <h2 class="blog-list-year">{year}</h2>
            <div class="blog-list-posts">
              {yearPosts.map((post) => (
                <article class="blog-list-article" style={`--anim-order: ${animOrder++}`}>
                  <time class="blog-list-date" datetime={post.data.date.toISOString()}>
                    {formatShortDate(post.data.date)}
                  </time>
                  <div class="blog-list-main">
                    <a href={`${site}/blog/${post.slug}.html`} class="blog-list-title">
                      {post.data.title}
                    </a>
                    <div class="blog-list-tags">
                      {post.data.tags?.map((tag) => (
                        <span class="blog-list-tag">{tag}</span>
                      )) ?? null}
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ));
    })()}
  </div>
</Layout>

<style>
  .blog-list-academic {
    --accent: #2c5282;
    --accent-rust: #b85c38;
    background: #f9f9f9;
    color: #1a1a1a;
    max-width: 42rem;
    margin: 0 auto;
  }

  .blog-list-heading {
    font-family: "Playfair Display", "Merriweather", Georgia, serif;
    font-size: 2rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 3rem;
    letter-spacing: -0.02em;
  }

  .blog-list-section {
    margin-bottom: 3rem;
  }

  .blog-list-year {
    font-family: Inter, system-ui, -apple-system, sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #737373;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.25rem;
  }

  .blog-list-posts {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .blog-list-article {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1.5rem;
    align-items: start;
    padding: 1rem 1.25rem;
    margin: 0 -1.25rem;
    border-radius: 0.375rem;
    cursor: pointer;
    transition: background 0.2s ease;
    animation: blog-slide-in 0.5s ease-out both;
    animation-delay: calc(var(--anim-order, 0) * 0.06s);
  }

  .blog-list-article:hover {
    background: #f0f0f0;
  }

  .blog-list-article:hover .blog-list-title {
    text-decoration: underline;
    text-underline-offset: 3px;
    color: var(--accent);
  }

  @keyframes blog-slide-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .blog-list-date {
    width: 80px;
    flex-shrink: 0;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
    font-size: 0.8125rem;
    color: #737373;
    padding-top: 0.125rem;
  }

  .blog-list-main {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .blog-list-title {
    font-family: "Merriweather", "Playfair Display", Georgia, serif;
    font-size: 1.0625rem;
    font-weight: 500;
    color: #1a1a1a;
    text-decoration: none;
    transition: color 0.2s ease, text-decoration 0.2s ease;
    line-height: 1.4;
  }

  .blog-list-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .blog-list-tag {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    font-weight: 500;
    color: #525252;
    background: #e8e8e8;
    padding: 0.2rem 0.5rem;
    border-radius: 0.2rem;
    border: 1px solid #e0e0e0;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .blog-list-article:hover .blog-list-tag {
    background: #e0e0e0;
    border-color: #d4d4d4;
  }
</style>
