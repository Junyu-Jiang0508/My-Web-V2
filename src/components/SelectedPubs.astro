---
import publications from '../data/publications.json';
import researchData from '../data/research.json';
import profile from '../data/profile.json';

const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '') || '/';

// Flatten all publications from all categories and filter by highlight
const allPubs = Object.values(publications).flat();
const highlightedPubs = allPubs
  .filter((p) => p.highlight === true)
  .sort((a, b) => (b.year || 0) - (a.year || 0)); // Sort by year descending

// Convert research.json items to Selected Publications format
const researchAsPubs = researchData.map((r) => {
  const year = r.date ? parseInt(r.date.slice(0, 4), 10) : null;
  const links = {};
  if (r.links?.paper) {
    const paperUrl = r.links.paper.startsWith('http') ? r.links.paper : `${base}${r.links.paper.startsWith('/') ? '' : '/'}${r.links.paper}`;
    links.pdf = paperUrl;
  }
  if (r.links?.code) links.code = r.links.code;
  if (r.links?.slides) links.slides = r.links.slides;
  return {
    title: r.title,
    authors: 'Jiang, J.*',
    venue: r.tags?.length ? r.tags.join(', ') : 'Research Project',
    year,
    links: Object.keys(links).length ? links : { code: null },
    highlight: true,
  };
}).sort((a, b) => (b.year || 0) - (a.year || 0));

// Merge and deduplicate by title (publications take precedence)
const pubTitles = new Set(highlightedPubs.map((p) => p.title.toLowerCase().trim()));
const researchOnly = researchAsPubs.filter((r) => !pubTitles.has(r.title.toLowerCase().trim()));
const mergedPubs = [...highlightedPubs, ...researchOnly].sort((a, b) => (b.year || 0) - (a.year || 0));

// Bold the user's name in authors (e.g. "Jiang, J.*" when profile name is "Junyu Jiang")
const boldAuthorName = (authors: string) => {
  const lastName = profile.name.split(' ').pop() || '';
  if (!lastName) return authors;
  const regex = new RegExp(`(${lastName},?\\s*J\\.?\\*?)`, 'g');
  return authors.replace(regex, '<strong>$1</strong>');
};

// Get title link: prefer pdf, else code, else data, else slides
const getTitleLink = (links: Record<string, string | null> | undefined) => {
  if (!links) return null;
  return links.pdf || links.code || links.data || links.slides || null;
};
---

<section id="selected-publications" class="px-4 py-12 md:py-16">
  <div class="mx-auto max-w-3xl">
    <h2 class="mb-6 text-xl font-semibold text-gray-900">Selected Publications</h2>
    <ul class="space-y-6">
      {mergedPubs.map((pub) => {
        const titleLink = getTitleLink(pub.links);
        const yearStr = pub.year ? `, ${pub.year}` : '';
        return (
          <li class="border-b border-gray-100 pb-6 last:border-0 last:pb-0">
            {/* Line 1: Title (bold, link if available) */}
            <div class="mb-1">
              {titleLink ? (
                <a
                  href={titleLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-semibold text-gray-900 underline decoration-gray-300 underline-offset-2 transition-colors hover:decoration-gray-500"
                >
                  {pub.title}
                </a>
              ) : (
                <span class="font-semibold text-gray-900">{pub.title}</span>
              )}
            </div>
            {/* Line 2: Authors (bold user's name) */}
            <div class="mb-1 text-sm text-gray-700" set:html={boldAuthorName(pub.authors)} />
            {/* Line 3: Venue and Year (italic) */}
            <div class="mb-2 text-sm italic text-gray-600">
              {pub.venue}
              {yearStr}
            </div>
            {/* Line 4: Badges [PDF], [Code], [Data], [Slides] */}
            <div class="flex flex-wrap gap-2 text-xs">
              {pub.links?.pdf && (
                <a
                  href={pub.links.pdf}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-gray-600 underline decoration-gray-300 underline-offset-1 hover:text-gray-900"
                >
                  [PDF]
                </a>
              )}
              {pub.links?.code && (
                <a
                  href={pub.links.code}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-gray-600 underline decoration-gray-300 underline-offset-1 hover:text-gray-900"
                >
                  [Code]
                </a>
              )}
              {pub.links?.data && (
                <a
                  href={pub.links.data}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-gray-600 underline decoration-gray-300 underline-offset-1 hover:text-gray-900"
                >
                  [Data]
                </a>
              )}
              {pub.links?.slides && (
                <a
                  href={pub.links.slides}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-gray-600 underline decoration-gray-300 underline-offset-1 hover:text-gray-900"
                >
                  [Slides]
                </a>
              )}
            </div>
          </li>
        );
      })}
    </ul>
  </div>
</section>
