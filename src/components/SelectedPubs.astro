---
import publications from '../data/publications.json';
import profile from '../data/profile.json';

// Single source of truth: my_pubs.bib → publications.json (via update_pubs.py)
const allPubs = Object.values(publications).flat();
const highlightedPubs = allPubs
  .filter((p) => p.highlight === true)
  .sort((a, b) => (b.year || 0) - (a.year || 0));

// Bold the user's name in authors (e.g. "Jiang, J.*" when profile name is "Junyu Jiang")
const boldAuthorName = (authors: string) => {
  const lastName = profile.name.split(' ').pop() || '';
  if (!lastName) return authors;
  const regex = new RegExp(`(${lastName},?\\s*J\\.?\\*?)`, 'g');
  return authors.replace(regex, '<strong>$1</strong>');
};

// Title links to code (GitHub) when available
const getTitleLink = (links: Record<string, string | null> | undefined) => links?.code || null;
---

<section id="selected-publications" class="px-4 py-12 md:py-16">
  <div class="mx-auto max-w-3xl">
    <h2 class="mb-6 text-xl font-semibold text-gray-900">Selected Works</h2>
    <ul class="space-y-6">
      {highlightedPubs.map((pub) => {
        const titleLink = getTitleLink(pub.links);
        const yearStr = pub.year ? `, ${pub.year}` : '';
        return (
          <li class="border-b border-gray-100 pb-6 last:border-0 last:pb-0">
            {/* Line 1: Title (bold, link if available) - line-height & break for mobile */}
            <div class="mb-1 leading-relaxed break-words">
              {titleLink ? (
                <a
                  href={titleLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-semibold text-gray-900 underline decoration-gray-300 underline-offset-2 transition-colors hover:decoration-gray-500"
                >
                  {pub.title}
                </a>
              ) : (
                <span class="font-semibold text-gray-900">{pub.title}</span>
              )}
            </div>
            {/* Line 2: Authors (bold user's name) */}
            <div class="mb-1 text-sm text-gray-700" set:html={boldAuthorName(pub.authors)} />
            {/* Line 3: Venue and Year (italic) */}
            <div class="mb-2 text-sm italic text-gray-600">
              {pub.venue}
              {yearStr}
            </div>
          </li>
        );
      })}
    </ul>
  </div>
</section>
