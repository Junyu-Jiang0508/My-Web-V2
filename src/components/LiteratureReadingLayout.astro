---
import Layout from '../layouts/Layout.astro';
import GiscusComments from './GiscusComments.astro';

interface Props {
  title: string;
  date: string;
}

const { title, date } = Astro.props;
---

<Layout title={title} fullWidth={true}>
  <article class="literature-reading">
    <div class="literature-grid">
      <!-- Sticky TOC (left) -->
      <aside class="literature-toc" aria-label="Table of contents">
        <nav id="toc-nav" class="toc-nav">
          <p class="toc-title">CONTENTS</p>
          <ul id="toc-list" class="toc-list"></ul>
        </nav>
      </aside>
      <!-- Main content -->
      <div class="literature-main">
        <header class="mb-10">
          <h1 class="mb-2 text-3xl font-bold tracking-tight text-slate-900">{title}</h1>
          <time class="block text-sm text-slate-500" datetime={date}>{date}</time>
        </header>

        <!-- Dashboard: Stats + Filters -->
        <div id="reading-dashboard" class="reading-dashboard">
          <div class="dashboard-stats">
            <div class="stat-card" id="stat-total">
              <span class="stat-value" id="stat-total-value">0</span>
              <span class="stat-label">Total</span>
            </div>
            <div class="stat-card" id="stat-books">
              <span class="stat-value" id="stat-books-value">0</span>
              <span class="stat-label">Books</span>
            </div>
            <div class="stat-card" id="stat-papers">
              <span class="stat-value" id="stat-papers-value">0</span>
              <span class="stat-label">Papers</span>
            </div>
          </div>
          <div class="dashboard-filters">
            <div class="filter-group">
              <span class="filter-label">Type:</span>
              <div class="filter-pills">
                <button type="button" class="filter-pill active" data-filter-type="all">All</button>
                <button type="button" class="filter-pill" data-filter-type="book">Books</button>
                <button type="button" class="filter-pill" data-filter-type="paper">Papers</button>
              </div>
            </div>
            <div class="filter-group">
              <span class="filter-label">Language:</span>
              <div class="filter-pills filter-pills-lang">
                <button type="button" class="filter-pill active" data-filter-lang="all">All</button>
                <button type="button" class="filter-pill" data-filter-lang="zh">Chinese</button>
                <button type="button" class="filter-pill" data-filter-lang="en">English</button>
              </div>
            </div>
            <div class="filter-group">
              <label for="filter-field" class="filter-label">Field:</label>
              <select id="filter-field" class="filter-select">
                <option value="">All Fields</option>
              </select>
            </div>
            <div class="filter-group">
              <label for="filter-subfield" class="filter-label">Subfield:</label>
              <select id="filter-subfield" class="filter-select">
                <option value="">All Subfields</option>
              </select>
            </div>
          </div>
          <p class="dashboard-count" id="dashboard-count" aria-live="polite">Showing 0 of 0 items</p>
        </div>

        <div class="literature-content">
          <slot />
        </div>

        <GiscusComments />
      </div>
    </div>
  </article>

  <script>
    // Step 1: Wrap h3 (Books) and h4 (Papers) in details/summary accordion
    function wrapAccordionSections() {
      const content = document.querySelector('.literature-content');
      if (!content) return;

      const children = Array.from(content.children);

      // Find Books Reading section (h2 with id or text "Books Reading")
      let inBooks = false;
      let inPaper = false;
      let booksStartIdx = -1;
      let paperStartIdx = -1;

      children.forEach((el, i) => {
        if (el.tagName === 'H2') {
          const id = (el.id || '').toLowerCase();
          const text = (el.textContent || '').toLowerCase();
          if (id.includes('books-reading') || text.includes('books reading')) {
            inBooks = true;
            inPaper = false;
            booksStartIdx = i + 1;
          } else if (id.includes('paper-reading') || text.includes('paper reading')) {
            inBooks = false;
            inPaper = true;
            paperStartIdx = i + 1;
          }
        }
      });

      const toReplace = [];

      // Wrap Books: each h3 and its content until next h3
      if (booksStartIdx >= 0) {
        for (let i = booksStartIdx; i < children.length; i++) {
          const el = children[i];
          if (el.tagName === 'H2') break;
          if (el.tagName === 'H3') {
            const siblings = [];
            for (let j = i + 1; j < children.length; j++) {
              const next = children[j];
              if (next.tagName === 'H3' || next.tagName === 'H2') break;
              siblings.push(next);
            }
            toReplace.push({ type: 'book', heading: el, siblings });
          }
        }
      }

      // Wrap Papers: each h4 and its content until next h4 or h3
      if (paperStartIdx >= 0) {
        for (let i = paperStartIdx; i < children.length; i++) {
          const el = children[i];
          if (el.tagName === 'H2') break;
          if (el.tagName === 'H4') {
            const siblings = [];
            for (let j = i + 1; j < children.length; j++) {
              const next = children[j];
              if (next.tagName === 'H4' || next.tagName === 'H3' || next.tagName === 'H2') break;
              siblings.push(next);
            }
            toReplace.push({ type: 'paper', heading: el, siblings });
          }
        }
      }

      toReplace.forEach(({ type, heading, siblings }) => {
        const details = document.createElement('details');
        details.className = 'log-accordion';
        details.dataset.type = type;

        const summary = document.createElement('summary');
        summary.className = 'log-accordion-summary';
        const title = heading.textContent || '';
        const headingId = heading.id || heading.textContent?.toLowerCase().replace(/\s+/g, '-').replace(/[^\w\u4e00-\u9fff-]/g, '') || '';
        const titleSpan = document.createElement('span');
        titleSpan.className = 'log-accordion-title';
        titleSpan.textContent = title;
        const iconSpan = document.createElement('span');
        iconSpan.className = 'log-accordion-icon';
        iconSpan.textContent = '+';
        summary.appendChild(titleSpan);
        summary.appendChild(iconSpan);
        if (headingId) details.id = headingId;

        const body = document.createElement('div');
        body.className = 'log-accordion-body';
        siblings.forEach((s) => body.appendChild(s));

        details.appendChild(summary);
        details.appendChild(body);
        content.replaceChild(details, heading);

        details.addEventListener('toggle', () => {
          iconSpan.textContent = details.open ? '−' : '+';
        });
      });
    }

    // Step 2 & 3: Dashboard stats, filtering
    function initDashboard() {
      wrapAccordionSections();

      const entries = document.querySelectorAll('.literature-content .log-accordion[data-type]');
      const statTotal = document.getElementById('stat-total-value');
      const statBooks = document.getElementById('stat-books-value');
      const statPapers = document.getElementById('stat-papers-value');
      const fieldSelect = document.getElementById('filter-field');
      const subfieldSelect = document.getElementById('filter-subfield');
      const countText = document.getElementById('dashboard-count');
      const typePills = document.querySelectorAll('.filter-pill[data-filter-type]');
      const langPills = document.querySelectorAll('.filter-pill[data-filter-lang]');

      const totalBooks = [...entries].filter((e) => e.dataset.type === 'book').length;
      const totalPapers = [...entries].filter((e) => e.dataset.type === 'paper').length;
      const total = entries.length;

      function updateStats(visibleTotal, visibleBooks, visiblePapers) {
        statTotal.textContent = visibleTotal;
        statBooks.textContent = visibleBooks;
        statPapers.textContent = visiblePapers;
        countText.textContent = `Showing ${visibleTotal} of ${total} items`;
      }

      function getFields() {
        const fields = new Set();
        entries.forEach((e) => {
          const f = e.dataset.field;
          if (f) fields.add(f.trim());
        });
        return [...fields].sort();
      }

      function getSubfields() {
        const subfields = new Set();
        entries.forEach((e) => {
          const s = e.dataset.subfield;
          if (s) subfields.add(s.trim());
        });
        return [...subfields].sort();
      }

      function populateField() {
        const fields = getFields();
        fieldSelect.innerHTML = '<option value="">All Fields</option>';
        fields.forEach((f) => {
          const opt = document.createElement('option');
          opt.value = f;
          opt.textContent = f;
          fieldSelect.appendChild(opt);
        });
      }

      function populateSubfield() {
        const fieldFilter = fieldSelect.value;
        const subfields = new Set();
        entries.forEach((e) => {
          if (fieldFilter && e.dataset.field !== fieldFilter) return;
          const s = e.dataset.subfield;
          if (s) subfields.add(s.trim());
        });
        subfieldSelect.innerHTML = '<option value="">All Subfields</option>';
        [...subfields].sort().forEach((s) => {
          const opt = document.createElement('option');
          opt.value = s;
          opt.textContent = s;
          subfieldSelect.appendChild(opt);
        });
      }

      function applyFilters() {
        const typeFilter = document.querySelector('.filter-pill[data-filter-type].active')?.dataset.filterType || 'all';
        const langFilter = document.querySelector('.filter-pill[data-filter-lang].active')?.dataset.filterLang || 'all';
        const fieldFilter = fieldSelect.value;
        const subfieldFilter = subfieldSelect.value;

        let visible = 0;
        let visibleBooks = 0;
        let visiblePapers = 0;

        entries.forEach((entry) => {
          const type = entry.dataset.type;
          const lang = entry.dataset.lang || 'en';
          const field = entry.dataset.field || '';
          const subfield = entry.dataset.subfield || '';
          const typeMatch = typeFilter === 'all' || type === typeFilter;
          const langMatch = langFilter === 'all' || lang === langFilter;
          const fieldMatch = !fieldFilter || field === fieldFilter;
          const subfieldMatch = !subfieldFilter || subfield === subfieldFilter;
          const show = typeMatch && langMatch && fieldMatch && subfieldMatch;

          entry.style.display = show ? '' : 'none';
          if (show) {
            visible++;
            if (type === 'book') visibleBooks++;
            else if (type === 'paper') visiblePapers++;
          }
        });

        updateStats(visible, visibleBooks, visiblePapers);
      }

      // Initial stats
      updateStats(total, totalBooks, totalPapers);
      populateField();
      populateSubfield();

      // Type filter pills
      typePills.forEach((pill) => {
        pill.addEventListener('click', () => {
          typePills.forEach((p) => p.classList.remove('active'));
          pill.classList.add('active');
          applyFilters();
        });
      });

      // Language filter pills
      langPills.forEach((pill) => {
        pill.addEventListener('click', () => {
          langPills.forEach((p) => p.classList.remove('active'));
          pill.classList.add('active');
          applyFilters();
        });
      });

      // Field select: when changed, update subfield options and apply filter
      fieldSelect.addEventListener('change', () => {
        populateSubfield();
        subfieldSelect.value = '';
        applyFilters();
      });

      subfieldSelect.addEventListener('change', applyFilters);
    }

    function buildTOC() {
      const main = document.querySelector('.literature-main');
      const tocList = document.getElementById('toc-list');
      if (!main || !tocList) return;

      const headings = main.querySelectorAll('h2');
      const accordions = main.querySelectorAll('.log-accordion');
      if (headings.length === 0 && accordions.length === 0) return;

      tocList.innerHTML = '';
      const sections = [];

      headings.forEach((h) => {
        const id = h.id || h.textContent?.toLowerCase().replace(/\s+/g, '-').replace(/[^\w\u4e00-\u9fff-]/g, '') || '';
        if (!id) return;
        h.id = id;

        const li = document.createElement('li');
        li.className = 'toc-item toc-h2';
        li.dataset.targetId = id;
        const a = document.createElement('a');
        a.href = `#${id}`;
        a.textContent = h.textContent || '';
        a.className = 'toc-link';
        a.addEventListener('click', (e) => {
          e.preventDefault();
          document.getElementById(id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
        li.appendChild(a);
        tocList.appendChild(li);
        sections.push(h);
      });

      accordions.forEach((acc) => {
        const id = acc.id;
        const title = acc.querySelector('.log-accordion-title')?.textContent || '';
        if (!id || !title) return;

        const li = document.createElement('li');
        li.className = 'toc-item toc-h3';
        li.dataset.targetId = id;
        const a = document.createElement('a');
        a.href = `#${id}`;
        a.textContent = title;
        a.className = 'toc-link';
        a.addEventListener('click', (e) => {
          e.preventDefault();
          document.getElementById(id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
        li.appendChild(a);
        tocList.appendChild(li);
        sections.push(acc);
      });

      const items = tocList.querySelectorAll('.toc-item');
      function getActiveSection() {
        const viewportTop = 120;
        let active = null;
        for (const s of sections) {
          const rect = s.getBoundingClientRect();
          if (rect.top <= viewportTop) active = s;
        }
        return active?.id || sections[0]?.id || '';
      }
      function updateActive() {
        const activeId = getActiveSection();
        items.forEach((item) => {
          item.classList.toggle('active', item.dataset.targetId === activeId);
        });
      }
      window.addEventListener('scroll', updateActive, { passive: true });
      updateActive();
    }

    function init() {
      initDashboard();
      buildTOC();
    }

    document.addEventListener('DOMContentLoaded', init);
    document.addEventListener('astro:page-load', init);
  </script>
</Layout>

<style>
  .literature-reading {
    --navy: #1e3a5f;
    --navy-light: #2c5282;
    --cool-gray: #64748b;
    --cool-gray-light: #94a3b8;
    --accent-blue: #3b82f6;
    --card-bg: #f8fafc;
    --timeline-dot: #1e3a5f;
  }

  .literature-grid {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 3rem;
    max-width: 72rem;
    margin: 0 auto;
  }

  @media (max-width: 767px) {
    .literature-grid {
      grid-template-columns: 1fr;
    }
    .literature-toc {
      display: none !important;
    }
  }

  .literature-main {
    min-width: 0;
  }

  .literature-toc {
    position: sticky;
    top: 6rem;
    align-self: start;
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
  }

  .literature-content :global(h2),
  .literature-content :global(.log-accordion) {
    scroll-margin-top: 6rem;
  }
</style>

<style is:global>
  .literature-toc .toc-title {
    font-family: "Times New Roman", "SimSun", "宋体", serif !important;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: #999;
    text-transform: uppercase;
    margin: 0 0 0.5rem 0;
  }

  .literature-toc .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .literature-toc .toc-item {
    margin-bottom: 0.35rem;
  }

  .literature-toc .toc-item.toc-h3 .toc-link {
    font-size: 0.6875rem;
    padding-left: 1rem;
  }

  .literature-toc .toc-link {
    display: block;
    padding: 0.3rem 0 0.3rem 0.75rem;
    border-left: 2px solid #eee;
    font-family: "Times New Roman", "SimSun", "宋体", serif !important;
    font-size: 0.75rem;
    font-weight: 500;
    color: #999;
    text-decoration: none;
    transition: all 0.2s ease;
    line-height: 1.45;
  }

  .literature-toc .toc-link:hover {
    color: #555;
  }

  .literature-toc .toc-item.active .toc-link {
    border-left-color: #1a1a1a;
    color: #1a1a1a;
    font-weight: 700;
  }
</style>

<style>
  /* Dashboard - 极简学术风 */
  .reading-dashboard {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.25rem 0;
    margin-bottom: 2rem;
    border-top: 1px solid #eaeaea;
    border-bottom: 1px solid #eaeaea;
  }

  .dashboard-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    align-items: baseline;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
  }

  .stat-value {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
    font-size: 1.5rem;
    font-weight: 600;
    color: #111111;
    line-height: 1.2;
  }

  .stat-label {
    font-size: 11px;
    font-weight: 500;
    color: #737373;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .dashboard-filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .filter-label {
    font-size: 11px;
    font-weight: 500;
    color: #737373;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .filter-pills {
    display: flex;
    gap: 0.25rem;
  }

  .filter-pill {
    padding: 0.35rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    border-radius: 0.25rem;
    border: 1px solid #e5e5e5;
    background: white;
    color: #737373;
    cursor: pointer;
    transition: all 0.15s;
  }

  .filter-pill:hover {
    border-color: #737373;
    color: #111111;
  }

  .filter-pill.active {
    background: #111111;
    border-color: #111111;
    color: white;
  }

  .filter-select {
    padding: 0.35rem 0.75rem;
    font-size: 0.8125rem;
    border-radius: 0.25rem;
    border: 1px solid #e5e5e5;
    background: white;
    color: #111111;
    min-width: 140px;
  }

  .dashboard-count {
    font-size: 11px;
    color: #737373;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Accordion 折叠卡片 */
  .log-accordion {
    margin-bottom: 0.5rem;
    border: none;
    scroll-margin-top: 6rem;
  }

  .log-accordion-summary {
    list-style: none;
    cursor: pointer;
    padding: 0.75rem 1rem;
    margin-left: -1.5rem;
    padding-left: 2rem;
    border-left: 1px solid #eaeaea;
    transition: background 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .log-accordion-summary::-webkit-details-marker {
    display: none;
  }

  .log-accordion-summary::marker {
    display: none;
  }

  .log-accordion-summary:hover {
    background: #f9f9f9;
  }

  .log-accordion[open] .log-accordion-summary {
    border-left-color: #737373;
  }

  .log-accordion-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #111111;
  }

  .log-accordion-icon {
    font-size: 1rem;
    font-weight: 300;
    color: #737373;
    flex-shrink: 0;
    margin-left: 0.5rem;
  }

  .log-accordion-body {
    margin-left: 1.5rem;
    padding-left: 1.5rem;
    border-left: 1px solid #eaeaea;
    padding-top: 0.5rem;
    padding-bottom: 1rem;
  }

  .log-accordion-body > *:first-child {
    margin-top: 0;
  }

  /* Reading entry wrapper */
  .literature-content :global(.reading-entry) {
    margin-bottom: 1.5rem;
  }

  /* Timeline + Card styling for content */
  .literature-content {
    position: relative;
    padding-left: 1.5rem;
    border-left: 2px solid #e2e8f0;
    font-family: "Times New Roman", "SimSun", "宋体", serif;
    margin-left: 0.5rem;
  }

  .literature-content :global(h2) {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--navy);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .literature-content :global(h2:first-child) {
    margin-top: 0;
  }

  .literature-content :global(h3) {
    font-size: 1rem;
    font-weight: 600;
    color: #111111;
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .literature-content :global(h4) {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #737373;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }

  .literature-content :global(ul) {
    margin: 0.5rem 0 1rem 0;
    padding-left: 1.5rem;
    list-style: none;
  }

  .literature-content :global(ul li) {
    margin-bottom: 0.5rem;
    line-height: 1.6;
    position: relative;
    padding-left: 1rem;
  }

  .literature-content :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 4px;
    height: 4px;
    background: rgba(0, 0, 0, 0.25);
    border-radius: 1px;
  }

  .literature-content :global(ul ul) {
    padding-left: 1rem;
    margin-top: 0.25rem;
  }

  /* 文献引用块 Citation Block - Paper/Book 行 */
  .literature-content :global(ul li:has(strong:first-child)) {
    font-family: Georgia, "Times New Roman", "SimSun", "宋体", serif;
    font-size: 0.9rem;
    color: #404040;
    padding: 0.75rem 1rem;
    margin-left: -1.5rem;
    padding-left: 1.5rem;
    border-left: 3px solid #d4d4d4;
    background: transparent;
    margin-bottom: 0.75rem;
  }

  /* Micro-badges: **Paper:**, **Previous Problems:** 等 */
  .literature-content :global(ul li strong:first-child) {
    font-size: 11px;
    font-weight: 600;
    font-family: Inter, system-ui, sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #666;
    display: inline-block;
    margin-right: 0.5rem;
  }

  .literature-content :global(ul li:has(strong:first-child)::before) {
    display: none;
  }

  /* 嵌套列表 - 极简符号 */
  .literature-content :global(ul ul li) {
    padding-left: 1rem;
  }

  .literature-content :global(ul ul li::before) {
    width: 3px;
    height: 3px;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 0;
  }

  .literature-content :global(a) {
    color: var(--accent-blue);
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }

  .literature-content :global(a:hover) {
    border-bottom-color: var(--accent-blue);
  }

  .literature-content :global(p) {
    margin: 0.5rem 0 1rem 0;
    line-height: 1.7;
    color: #334155;
  }
</style>
