---
import Layout from '../layouts/Layout.astro';

interface Props {
  title: string;
  date: string;
}

const { title, date } = Astro.props;
---

<Layout title={title} fullWidth={true}>
  <article class="literature-reading">
    <div class="literature-grid">
      <!-- Main content -->
      <div class="literature-main">
        <header class="mb-10">
          <h1 class="mb-2 text-3xl font-bold tracking-tight text-slate-900">{title}</h1>
          <time class="block text-sm text-slate-500" datetime={date}>{date}</time>
        </header>
        <div class="literature-content">
          <slot />
        </div>
      </div>

      <!-- Sticky TOC -->
      <aside class="literature-toc" aria-label="Table of contents">
        <nav id="toc-nav" class="toc-nav">
          <h3 class="toc-title">Contents</h3>
          <ul id="toc-list" class="toc-list"></ul>
        </nav>
      </aside>
    </div>
  </article>

  <script>
    function buildTOC() {
      const main = document.querySelector('.literature-main');
      const tocList = document.getElementById('toc-list');
      if (!main || !tocList) return;

      const headings = main.querySelectorAll('h2, h3');
      if (headings.length === 0) return;

      tocList.innerHTML = '';
      headings.forEach((h) => {
        const id = h.id || h.textContent?.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '') || '';
        if (!id) return;
        h.id = id;

        const li = document.createElement('li');
        li.className = `toc-item toc-${h.tagName.toLowerCase()}`;
        const a = document.createElement('a');
        a.href = `#${id}`;
        a.textContent = h.textContent || '';
        a.className = 'toc-link';
        li.appendChild(a);
        tocList.appendChild(li);
      });

      // Scroll spy
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              tocList.querySelectorAll('.toc-link').forEach((link) => {
                link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
              });
            }
          });
        },
        { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
      );
      headings.forEach((h) => observer.observe(h));
    }

    document.addEventListener('DOMContentLoaded', buildTOC);
    document.addEventListener('astro:page-load', buildTOC);
  </script>
</Layout>

<style>
  .literature-reading {
    --navy: #1e3a5f;
    --navy-light: #2c5282;
    --cool-gray: #64748b;
    --cool-gray-light: #94a3b8;
    --accent-blue: #3b82f6;
    --card-bg: #f8fafc;
    --timeline-dot: #1e3a5f;
  }

  .literature-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 72rem;
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .literature-grid {
      grid-template-columns: 1fr 240px;
      gap: 3rem;
    }
  }

  .literature-main {
    min-width: 0;
  }

  .literature-toc {
    display: none;
  }

  @media (min-width: 1024px) {
    .literature-toc {
      display: block;
      position: sticky;
      top: 6rem;
      align-self: start;
      max-height: calc(100vh - 8rem);
      overflow-y: auto;
    }
  }

  .toc-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--cool-gray);
    margin-bottom: 0.75rem;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.875rem;
  }

  .toc-item {
    margin-bottom: 0.25rem;
  }

  .toc-item.toc-h3 {
    padding-left: 1rem;
  }

  .toc-link {
    color: var(--cool-gray);
    text-decoration: none;
    display: block;
    padding: 0.25rem 0;
    border-left: 2px solid transparent;
    padding-left: 0.5rem;
    margin-left: -0.5rem;
    transition: color 0.15s, border-color 0.15s;
  }

  .toc-link:hover {
    color: var(--navy);
  }

  .toc-link.active {
    color: var(--navy);
    font-weight: 500;
    border-left-color: var(--accent-blue);
  }

  /* Timeline + Card styling for content */
  .literature-content {
    position: relative;
    padding-left: 1.5rem;
    border-left: 2px solid #e2e8f0;
    margin-left: 0.5rem;
  }

  .literature-content :global(h2) {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--navy);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .literature-content :global(h2:first-child) {
    margin-top: 0;
  }

  .literature-content :global(h3) {
    font-size: 1rem;
    font-weight: 600;
    color: var(--navy);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    position: relative;
    padding: 0.75rem 1rem;
    background: var(--card-bg);
    border-radius: 0.5rem;
    border-left: 4px solid var(--navy-light);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  }

  .literature-content :global(#books-reading ~ h3)::before {
    content: 'Book';
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: white;
    background: var(--navy);
    padding: 0.15rem 0.5rem;
    border-radius: 0.25rem;
    margin-right: 0.5rem;
    vertical-align: middle;
  }

  .literature-content :global(#paper-reading ~ h4)::before {
    content: 'Paper';
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: white;
    background: #0d9488;
    padding: 0.15rem 0.5rem;
    border-radius: 0.25rem;
    margin-right: 0.5rem;
    vertical-align: middle;
  }

  .literature-content :global(h4) {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--cool-gray);
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
    position: relative;
    padding-left: 1rem;
  }

  .literature-content :global(h4)::after {
    content: '';
    position: absolute;
    left: -1.75rem;
    top: 0.5rem;
    width: 8px;
    height: 8px;
    background: var(--timeline-dot);
    border-radius: 50%;
    border: 2px solid white;
    box-shadow: 0 0 0 2px #e2e8f0;
  }

  .literature-content :global(ul) {
    margin: 0.5rem 0 1rem 0;
    padding-left: 1.5rem;
  }

  .literature-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .literature-content :global(strong) {
    color: var(--navy);
    font-weight: 600;
  }

  .literature-content :global(a) {
    color: var(--accent-blue);
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }

  .literature-content :global(a:hover) {
    border-bottom-color: var(--accent-blue);
  }

  .literature-content :global(p) {
    margin: 0.5rem 0 1rem 0;
    line-height: 1.7;
    color: #334155;
  }

  /* Academic blockquote / Key Insights style */
  .literature-content :global(ul li:has(strong)) {
    padding: 0.75rem 1rem;
    margin-left: -1rem;
    padding-left: 1.5rem;
    border-left: 3px solid #cbd5e1;
    background: #f8fafc;
    border-radius: 0 0.375rem 0.375rem 0;
    margin-bottom: 0.75rem;
  }

  .literature-content :global(ul li:has(strong:first-child)) {
    font-family: 'Merriweather', 'Georgia', serif;
    font-size: 0.9375rem;
    font-style: normal;
    line-height: 1.7;
  }
</style>
