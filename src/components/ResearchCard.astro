---
const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '') || '';

interface ResearchLinks {
  paper?: string;
  code?: string;
  demo?: string;
  slides?: string;
}

interface ResearchProject {
  title: string;
  description: string;
  image: string;
  links: ResearchLinks;
  tags: string[];
  date: string;
}

interface Props {
  project: ResearchProject;
}

const { project } = Astro.props;

const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
};

const linkEntries = [
  { key: 'paper', label: 'Paper', icon: '📄' },
  { key: 'code', label: 'Code', icon: '💻' },
  { key: 'demo', label: 'Demo', icon: '🔗' },
  { key: 'slides', label: 'Slides', icon: '📊' },
] as const;
---

<article class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-shadow hover:shadow-md md:p-6">
  <div class="flex flex-col">
    <h2 class="mb-2 text-lg font-bold text-gray-900 md:text-xl">{project.title}</h2>
    <time class="mb-2 block text-sm text-gray-500" datetime={project.date}>
      {formatDate(project.date)}
    </time>
    <p class="mb-3 text-sm leading-relaxed text-gray-600 md:text-base">{project.description}</p>
    {project.tags.length > 0 && (
      <div class="mb-3 flex flex-wrap gap-2">
        {project.tags.map((tag) => (
          <span
            class="rounded-full bg-gray-200 px-2.5 py-0.5 text-xs font-medium text-gray-700"
          >
            {tag}
          </span>
        ))}
      </div>
    )}
    <div class="mt-auto flex flex-wrap gap-2">
      {linkEntries.map(({ key, label, icon }) => {
        const url = project.links[key as keyof ResearchLinks];
        if (!url) return null;
        const isExternal = url.startsWith('http');
        const href = isExternal ? url : `${base}${url.startsWith('/') ? '' : '/'}${url}`;
        return (
          <a
            href={href}
            target={isExternal ? '_blank' : undefined}
            rel={isExternal ? 'noopener noreferrer' : undefined}
            class="inline-flex items-center gap-1.5 rounded-lg bg-gray-100 px-3 py-1.5 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-200"
          >
            <span>{icon}</span>
            {label}
          </a>
        );
      })}
    </div>
  </div>
</article>
