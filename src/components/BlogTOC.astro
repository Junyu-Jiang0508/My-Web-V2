---
/**
 * Auto-generated Table of Contents for blog posts.
 * Scans h2/h3 headings in the article and builds TOC. Only visible when headings exist.
 */
---

<nav id="blog-toc" class="blog-toc" aria-label="Table of contents" style="display: none;">
  <p class="blog-toc-title">目 录</p>
  <ol id="blog-toc-list" class="blog-toc-list"></ol>
</nav>

<script>
  function buildBlogTOC() {
    const article = document.querySelector('article');
    const toc = document.getElementById('blog-toc');
    const tocList = document.getElementById('blog-toc-list');
    if (!article || !toc || !tocList) return;

    const headings = article.querySelectorAll('.prose h2, .prose h3');
    if (headings.length === 0) return;

    toc.style.display = '';
    tocList.innerHTML = '';

    let h2Index = 0;
    let h3Index = 0;

    headings.forEach((h) => {
      let id = h.id;
      if (!id) {
        id = (h.textContent || '')
          .toLowerCase()
          .replace(/\s+/g, '-')
          .replace(/[^\w\u4e00-\u9fff-]/g, '')
          .replace(/-+/g, '-')
          .replace(/^-|-$/g, '') || 'section';
        h.id = id;
      }

      const li = document.createElement('li');
      const isH2 = h.tagName === 'H2';
      if (isH2) {
        h2Index++;
        h3Index = 0;
        li.className = 'blog-toc-item blog-toc-h2';
        li.dataset.num = String(h2Index);
      } else {
        h3Index++;
        li.className = 'blog-toc-item blog-toc-h3';
        li.dataset.num = `${h2Index}.${h3Index}`;
      }

      const a = document.createElement('a');
      a.href = `#${id}`;
      a.textContent = h.textContent || '';
      a.className = 'blog-toc-link';
      li.appendChild(a);
      tocList.appendChild(li);
    });
  }

  document.addEventListener('DOMContentLoaded', buildBlogTOC);
  document.addEventListener('astro:page-load', buildBlogTOC);
</script>

<style>
  .blog-toc {
    margin-bottom: 2.5rem;
    padding: 1.25rem 0;
    border-top: 1px solid #374151;
    border-bottom: 1px solid #374151;
    font-family: "Times New Roman", "SimSun", "宋体", serif;
  }

  .blog-toc-title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 1rem 0;
    letter-spacing: 0.2em;
    text-align: center;
  }

  .blog-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.8125rem;
  }

  .blog-toc-item {
    margin-bottom: 0.35rem;
    padding-left: 0;
    position: relative;
  }

  .blog-toc-item.blog-toc-h2 {
    font-weight: 600;
    padding-top: 0.25rem;
  }

  .blog-toc-item.blog-toc-h2::before {
    content: attr(data-num) ". ";
    color: #374151;
    margin-right: 0.25rem;
  }

  .blog-toc-item.blog-toc-h3 {
    padding-left: 1.25rem;
    font-weight: 400;
  }

  .blog-toc-item.blog-toc-h3::before {
    content: attr(data-num) " ";
    color: #6b7280;
    font-size: 0.75rem;
    margin-right: 0.25rem;
  }

  .blog-toc-link {
    color: #374151;
    text-decoration: none;
    display: inline;
    transition: color 0.15s;
  }

  .blog-toc-link:hover {
    color: #111827;
    text-decoration: underline;
  }
</style>
