---
/**
 * Auto-generated Table of Contents for blog posts.
 * Scans h2/h3 headings in the article and builds TOC. Only visible when headings exist.
 */
---

<nav id="blog-toc" class="blog-toc" aria-label="Table of contents" style="display: none;">
  <h3 class="blog-toc-title">Contents</h3>
  <ul id="blog-toc-list" class="blog-toc-list"></ul>
</nav>

<script>
  function buildBlogTOC() {
    const article = document.querySelector('article');
    const toc = document.getElementById('blog-toc');
    const tocList = document.getElementById('blog-toc-list');
    if (!article || !toc || !tocList) return;

    const headings = article.querySelectorAll('.prose h2, .prose h3');
    if (headings.length === 0) return;

    toc.style.display = '';
    tocList.innerHTML = '';

    headings.forEach((h) => {
      let id = h.id;
      if (!id) {
        id = (h.textContent || '')
          .toLowerCase()
          .replace(/\s+/g, '-')
          .replace(/[^\w\u4e00-\u9fff-]/g, '')
          .replace(/-+/g, '-')
          .replace(/^-|-$/g, '') || 'section';
        h.id = id;
      }

      const li = document.createElement('li');
      li.className = `blog-toc-item blog-toc-${h.tagName.toLowerCase()}`;
      const a = document.createElement('a');
      a.href = `#${id}`;
      a.textContent = h.textContent || '';
      a.className = 'blog-toc-link';
      li.appendChild(a);
      tocList.appendChild(li);
    });
  }

  document.addEventListener('DOMContentLoaded', buildBlogTOC);
  document.addEventListener('astro:page-load', buildBlogTOC);
</script>

<style>
  .blog-toc {
    margin-bottom: 2rem;
    padding: 1rem 1.25rem;
    background: #f8fafc;
    border-radius: 0.5rem;
    border: 1px solid #e2e8f0;
  }

  .blog-toc-title {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #64748b;
    margin: 0 0 0.75rem 0;
  }

  .blog-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.875rem;
  }

  .blog-toc-item {
    margin-bottom: 0.25rem;
  }

  .blog-toc-item.blog-toc-h3 {
    padding-left: 1rem;
  }

  .blog-toc-link {
    color: #475569;
    text-decoration: none;
    display: block;
    padding: 0.2rem 0;
    transition: color 0.15s;
  }

  .blog-toc-link:hover {
    color: #1e293b;
  }
</style>
