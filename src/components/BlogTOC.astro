---
/**
 * Sticky Sidebar Table of Contents for blog posts.
 * Auto-extracts H2/H3 from article, builds nested list, smooth scroll + scroll spy.
 */
---

<aside id="toc-sidebar" class="blog-toc-sidebar" aria-label="Table of contents" style="display: none;">
  <p class="blog-toc-label">CONTENTS</p>
  <nav id="blog-toc-nav">
    <ul id="blog-toc-list" class="blog-toc-list"></ul>
  </nav>
</aside>

<script>
  function slugify(text) {
    return (text || '')
      .toLowerCase()
      .replace(/\s+/g, '-')
      .replace(/[^\w\u4e00-\u9fff-]/g, '')
      .replace(/-+/g, '-')
      .replace(/^-|-$/g, '') || 'section';
  }

  function buildBlogTOC() {
    const article = document.querySelector('article.blog-article');
    const tocSidebar = document.getElementById('toc-sidebar');
    const tocList = document.getElementById('blog-toc-list');
    if (!article || !tocSidebar || !tocList) return;

    const headings = article.querySelectorAll('.blog-prose h2, .blog-prose h3');
    if (headings.length === 0) return;

    tocSidebar.style.display = '';
    tocList.innerHTML = '';

    let currentUl = tocList;
    let lastLevel = 1; // 1 = h2, 2 = h3

    headings.forEach((h) => {
      let id = h.id;
      if (!id) {
        id = slugify(h.textContent);
        h.id = id;
      }

      const isH2 = h.tagName === 'H2';
      const level = isH2 ? 1 : 2;

      if (level === 1) {
        currentUl = tocList;
      } else if (level === 2 && lastLevel === 1) {
        const lastLi = currentUl.lastElementChild;
        if (lastLi) {
          let nestedUl = lastLi.querySelector('ul');
          if (!nestedUl) {
            nestedUl = document.createElement('ul');
            nestedUl.className = 'blog-toc-sublist';
            lastLi.appendChild(nestedUl);
          }
          currentUl = nestedUl;
        }
      } else if (level === 1 && lastLevel === 2) {
        currentUl = tocList;
      }

      lastLevel = level;

      const li = document.createElement('li');
      li.className = isH2 ? 'blog-toc-h2' : 'blog-toc-h3';
      li.dataset.targetId = id;

      const a = document.createElement('a');
      a.href = `#${id}`;
      a.textContent = h.textContent || '';
      a.className = 'blog-toc-link';
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.getElementById(id);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });

      li.appendChild(a);
      currentUl.appendChild(li);
    });

    setupScrollSpy();
  }

  function setupScrollSpy() {
    const sections = document.querySelectorAll('.blog-prose h2[id], .blog-prose h3[id]');
    const items = document.querySelectorAll('.blog-toc-h2, .blog-toc-h3');
    if (sections.length === 0 || items.length === 0) return;

    const observerOptions = { rootMargin: '-100px 0px -60% 0px', threshold: 0 };
    const visible = new Map();

    function updateActive() {
      const intersecting = [...sections].filter((s) => visible.get(s.id));
      const sorted = intersecting.sort(
        (a, b) => a.getBoundingClientRect().top - b.getBoundingClientRect().top
      );
      const activeId = sorted[0]?.id || '';

      items.forEach((item) => {
        item.classList.toggle('active', item.dataset.targetId === activeId);
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          visible.set(entry.target.id, entry.isIntersecting);
        });
        updateActive();
      },
      observerOptions
    );

    sections.forEach((s) => observer.observe(s));
  }

  document.addEventListener('DOMContentLoaded', buildBlogTOC);
  document.addEventListener('astro:page-load', buildBlogTOC);
</script>

<style>
  .blog-toc-sidebar {
    position: sticky;
    top: 6rem;
    align-self: start;
    width: 100%;
    max-width: 250px;
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
  }

  .blog-toc-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: #999;
    text-transform: uppercase;
    margin: 0 0 0.75rem 0;
    font-family: Inter, system-ui, -apple-system, sans-serif;
  }

  .blog-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .blog-toc-sublist {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0 0;
    padding-left: 1rem;
  }

  .blog-toc-h2,
  .blog-toc-h3 {
    margin-bottom: 0.5rem;
    position: relative;
  }

  .blog-toc-link {
    display: block;
    padding: 0.4rem 0 0.4rem 1rem;
    border-left: 2px solid #eee;
    font-family: "JetBrains Mono", ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #999;
    text-decoration: none;
    transition: all 0.2s ease;
    line-height: 1.4;
  }

  .blog-toc-link:hover {
    color: #555;
  }

  .blog-toc-h2.active .blog-toc-link,
  .blog-toc-h3.active .blog-toc-link {
    border-left-color: #1a1a1a;
    color: #1a1a1a;
    font-weight: 700;
  }

  .blog-toc-h3 .blog-toc-link {
    font-size: 0.75rem;
    padding-left: 1.25rem;
  }

  @media (max-width: 767px) {
    .blog-toc-sidebar {
      display: none !important;
    }
  }
</style>
