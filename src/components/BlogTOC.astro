---
/**
 * Sticky Sidebar Table of Contents for blog posts.
 * Auto-extracts H2/H3 from article, builds nested list, smooth scroll + scroll spy.
 */
---

<aside id="toc-sidebar" class="blog-toc-sidebar" aria-label="Table of contents" style="display: none;">
  <p class="blog-toc-label">CONTENTS</p>
  <nav id="blog-toc-nav">
    <ul id="blog-toc-list" class="blog-toc-list"></ul>
  </nav>
</aside>

<script>
  function slugify(text) {
    return (text || '')
      .toLowerCase()
      .replace(/\s+/g, '-')
      .replace(/[^\w\u4e00-\u9fff-]/g, '')
      .replace(/-+/g, '-')
      .replace(/^-|-$/g, '') || 'section';
  }

  function buildBlogTOC() {
    const article = document.querySelector('article.blog-article');
    const tocSidebar = document.getElementById('toc-sidebar');
    const tocList = document.getElementById('blog-toc-list');
    if (!article || !tocSidebar || !tocList) return;

    const headings = article.querySelectorAll('.blog-prose h2, .blog-prose h3');
    if (headings.length === 0) return;

    tocSidebar.style.display = '';
    tocList.innerHTML = '';

    let currentUl = tocList;
    let lastLevel = 1; // 1 = h2, 2 = h3

    headings.forEach((h) => {
      let id = h.id;
      if (!id) {
        id = slugify(h.textContent);
        h.id = id;
      }

      const isH2 = h.tagName === 'H2';
      const level = isH2 ? 1 : 2;

      if (level === 1) {
        currentUl = tocList;
      } else if (level === 2 && lastLevel === 1) {
        const lastLi = currentUl.lastElementChild;
        if (lastLi) {
          let nestedUl = lastLi.querySelector('ul');
          if (!nestedUl) {
            nestedUl = document.createElement('ul');
            nestedUl.className = 'blog-toc-sublist';
            lastLi.appendChild(nestedUl);
          }
          currentUl = nestedUl;
        }
      } else if (level === 1 && lastLevel === 2) {
        currentUl = tocList;
      }

      lastLevel = level;

      const li = document.createElement('li');
      li.className = isH2 ? 'blog-toc-h2' : 'blog-toc-h3';
      li.dataset.targetId = id;

      const a = document.createElement('a');
      a.href = `#${id}`;
      a.textContent = h.textContent || '';
      a.className = 'blog-toc-link';
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.getElementById(id);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });

      li.appendChild(a);
      currentUl.appendChild(li);
    });

    setupScrollSpy();
  }

  function setupScrollSpy() {
    const links = document.querySelectorAll('.blog-toc-link');
    const items = document.querySelectorAll('.blog-toc-h2, .blog-toc-h3');
    if (links.length === 0) return;

    const observerOptions = { rootMargin: '-80px 0px -60% 0px', threshold: 0 };
    const headingIds = Array.from(links).map((a) => a.getAttribute('href')?.slice(1)).filter(Boolean);

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const id = entry.target.id;
        items.forEach((item) => {
          if (item.dataset.targetId === id) {
            items.forEach((i) => i.classList.remove('active'));
            item.classList.add('active');
          }
        });
      });
    }, observerOptions);

    headingIds.forEach((id) => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  }

  document.addEventListener('DOMContentLoaded', buildBlogTOC);
  document.addEventListener('astro:page-load', buildBlogTOC);
</script>

<style>
  .blog-toc-sidebar {
    position: sticky;
    top: 2rem;
    align-self: start;
    width: 100%;
    max-width: 250px;
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
    padding-left: 1rem;
    border-left: 1px solid #eaeaea;
  }

  .blog-toc-label {
    font-size: 11px;
    letter-spacing: 1px;
    color: #999;
    text-transform: uppercase;
    margin: 0 0 0.75rem 0;
    font-family: Inter, system-ui, -apple-system, sans-serif;
  }

  .blog-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 13px;
  }

  .blog-toc-sublist {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0 0;
    padding-left: 1rem;
  }

  .blog-toc-h2,
  .blog-toc-h3 {
    margin-bottom: 0.35rem;
    position: relative;
  }

  .blog-toc-h3 {
    font-size: 12px;
  }

  .blog-toc-link {
    color: #737373;
    text-decoration: none;
    display: block;
    transition: color 0.15s ease;
    line-height: 1.4;
  }

  .blog-toc-link:hover {
    color: #000000;
  }

  .blog-toc-h2.active .blog-toc-link,
  .blog-toc-h3.active .blog-toc-link {
    color: #000000;
    font-weight: 600;
  }

  .blog-toc-h2.active,
  .blog-toc-h3.active {
    border-left: 2px solid #000;
    margin-left: -1rem;
    padding-left: calc(1rem - 2px);
  }

  @media (max-width: 1023px) {
    .blog-toc-sidebar {
      display: none !important;
    }
  }
</style>
